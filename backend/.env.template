# MongoDB Atlas Connection Template
# Copy this to .env and replace with your actual values from MongoDB Atlas

PORT=5001

# Get this from MongoDB Atlas:
# 1. Go to your cluster → Click "Connect"
# 2. Choose "Connect your application"
# 3. Copy the connection string
# 4. Replace USERNAME, PASSWORD, and CLUSTER_ADDRESS below
# 5. Add /agileai before the ? (database name)
# 6. URL-encode special characters in password (@ becomes %40)

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER_ADDRESS.mongodb.net/agileai?retryWrites=true&w=majority

# Example (replace with your actual values):
# MONGODB_URI=mongodb+srv://myuser:mypass123@cluster0.abc123.mongodb.net/agileai?retryWrites=true&w=majority

JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development
